# Root-level ignores for monorepo publishing

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
*.iml

# Secrets and env files
.env
.env.*
!.env.example
**/.env
**/.env.*
!**/.env.example

# Logs
*.log
npm-debug.log*
yarn-error.log*
pnpm-debug.log*

# Flutter / Dart
frontend/.dart_tool/
frontend/.flutter-plugins-dependencies
frontend/.pub/
frontend/.pub-cache/
frontend/build/
frontend/**/build/
frontend/coverage/
frontend/android/.gradle/
frontend/android/local.properties

# Node / TypeScript
**/node_modules/
**/dist/
**/.next/
**/coverage/

# Go artifacts
**/bin/
**/*.exe
**/*.test

# Misc generated
*.swp
*.swo

# Backup of nested Git metadata (created for monorepo publish)
**/.git_backup_consumet/
